<% layout("./layouts/boilerplate.ejs") -%>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.3/dist/leaflet.css" />

<div class="container mt-4">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="form-card">
        <h2 class="fw-bold text-center mb-4">Edit Listing</h2>
        <form action="/listings/<%= listing._id %>?_method=put" method="post" class="needs-validation" novalidate enctype="multipart/form-data">
          <div class="mb-3">
            <label for="title" class="form-label">Title</label>
            <input id="title" name="listing[title]" class="form-control" required value="<%= listing.title %>">
            <div class="invalid-feedback">Title is required</div>
          </div>
          <div class="mb-3">
            <label for="description" class="form-label">Description</label>
            <textarea id="description" name="listing[description]" rows="4" class="form-control" required><%= listing.description %></textarea>
            <div class="invalid-feedback">Description is required</div>
          </div>
          <div class="mb-3">
            <label class="form-label">Current Image</label>
            <div class="d-flex align-items-center gap-3">
              <img src="<%= originalImage %>" class="rounded" style="max-width: 120px; height: 80px; object-fit: cover;" alt="Current image">
              <div style="flex:1">
                <label for="image" class="form-label mb-1" style="font-size: 0.85rem;">Upload new image (optional)</label>
                <input id="image" name="listing[image]" type="file" class="form-control" accept="image/*">
              </div>
            </div>
            <input type="hidden" name="listing[image][url]" value="<%= listing.image.url %>">
            <input type="hidden" name="listing[image][filename]" value="<%= listing.image.filename %>">
          </div>
          <div class="row g-3">
            <div class="col-md-4">
              <label for="price" class="form-label">Price (₹/night)</label>
              <input id="price" name="listing[price]" type="number" min="1000" class="form-control" required value="<%= listing.price %>">
              <div class="invalid-feedback">Price is required</div>
            </div>
            <div class="col-md-4">
              <label for="category" class="form-label">Category</label>
              <select class="form-control" id="category" name="listing[category]" required>
                <option value="">Select Category</option>
                <option <%= listing.category === "Trending" ? "selected" : "" %>>Trending</option>
                <option <%= listing.category === "Room" ? "selected" : "" %>>Room</option>
                <option <%= listing.category === "Amazing Views" ? "selected" : "" %>>Amazing Views</option>
                <option <%= listing.category === "Surfing" ? "selected" : "" %>>Surfing</option>
                <option <%= listing.category === "Amazing Pools" ? "selected" : "" %>>Amazing Pools</option>
                <option <%= listing.category === "Beach" ? "selected" : "" %>>Beach</option>
                <option <%= listing.category === "Cabins" ? "selected" : "" %>>Cabins</option>
                <option <%= listing.category === "Mountain" ? "selected" : "" %>>Mountain</option>
                <option <%= listing.category === "Iconic Cities" ? "selected" : "" %>>Iconic Cities</option>
              </select>
              <div class="invalid-feedback">Category is required</div>
            </div>
            <div class="col-md-4">
              <label for="country" class="form-label">Country</label>
              <input id="country" name="listing[country]" class="form-control" required value="<%= listing.country %>">
              <div class="invalid-feedback">Country is required</div>
            </div>
          </div>
          <div class="mb-3 mt-3">
            <label for="location" class="form-label">Location</label>
            <input id="location" name="listing[location]" class="form-control" required value="<%= listing.location %>">
            <div class="invalid-feedback">Location is required</div>
            <div id="map-preview" style="height: 220px; width: 100%; margin-top: 12px;"></div>
          </div>
          <input type="hidden" id="lat" name="listing[lat]">
          <input type="hidden" id="lng" name="listing[lng]">
          <button class="btn btn-primary w-100 mt-3" type="submit">
            <i class="fa-solid fa-check me-1"></i> Update Listing
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.3/dist/leaflet.js"></script>
<script>
  let map, marker;
  function initMap(lat = 20.5937, lng = 78.9629) {
    if (map) map.remove();
    map = L.map('map-preview').setView([lat, lng], 4);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; OpenStreetMap contributors'
    }).addTo(map);
    marker = L.marker([lat, lng]).addTo(map);
  }
  async function updateMapFromLocation(locationText) {
    try {
      const url = `https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(locationText)}`;
      const res = await fetch(url, { headers: { 'User-Agent': 'wanderlust-app' } });
      const data = await res.json();
      if (data.length > 0) {
        const lat = parseFloat(data[0].lat);
        const lon = parseFloat(data[0].lon);
        map.setView([lat, lon], 13);
        marker.setLatLng([lat, lon]);
        document.getElementById('lat').value = lat;
        document.getElementById('lng').value = lon;
      }
    } catch(err) { console.error('Geocoding error:', err); }
  }
  document.addEventListener("DOMContentLoaded", () => {
    <% if (listing.geometry && listing.geometry.coordinates) { %>
      initMap(<%= listing.geometry.coordinates[1] %>, <%= listing.geometry.coordinates[0] %>);
      map.setView([<%= listing.geometry.coordinates[1] %>, <%= listing.geometry.coordinates[0] %>], 13);
      marker.setLatLng([<%= listing.geometry.coordinates[1] %>, <%= listing.geometry.coordinates[0] %>]);
    <% } else { %>
      initMap();
    <% } %>
    const locationInput = document.getElementById("location");
    let timeout;
    locationInput.addEventListener("input", (e) => {
      clearTimeout(timeout);
      timeout = setTimeout(() => {
        if (e.target.value.length > 3) updateMapFromLocation(e.target.value);
      }, 500);
    });
  });
</script>