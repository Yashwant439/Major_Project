<% layout("./layouts/boilerplate.ejs") -%>

<div class="container mt-4">
  <h2 class="fw-bold mb-4"><i class="fa-solid fa-heart me-2" style="color: var(--accent);"></i>My Wishlist</h2>

  <% if (wishlistListings.length === 0) { %>
    <div class="empty-state">
      <i class="fa-regular fa-heart"></i>
      <h3>Your wishlist is empty</h3>
      <p>Save your favorite places by clicking the heart icon on any listing</p>
      <a href="/listings" class="btn btn-primary mt-3">Explore listings</a>
    </div>
  <% } else { %>
    <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4">
      <% wishlistListings.forEach((listing, i) => { %>
        <div class="col fade-in stagger-<%= (i % 6) + 1 %>">
          <div class="listing-card">
            <div class="card-img-wrapper">
              <a href="/listings/<%= listing._id %>">
                <img src="<%= listing.image.url %>" alt="<%= listing.title %>" loading="lazy">
                <div class="card-img-overlay-gradient"></div>
              </a>
              <button class="wishlist-heart active" onclick="toggleWishlist('<%= listing._id %>', this)" title="Remove from wishlist">
                <i class="fa-solid fa-heart"></i>
              </button>
              <div class="price-badge">&#8377;<%= listing.price.toLocaleString("en-IN") %>/night</div>
            </div>
            <div class="card-body">
              <div class="card-title"><%= listing.title %></div>
              <div class="card-location"><i class="fa-solid fa-location-dot me-1"></i><%= listing.location %>, <%= listing.country %></div>
              <div class="card-price">&#8377;<%= listing.price.toLocaleString("en-IN") %> <span>/ night</span></div>
            </div>
            <a href="/listings/<%= listing._id %>/book" class="book-now-btn">Book Now</a>
          </div>
        </div>
      <% }); %>
    </div>
  <% } %>
</div>

<script>
async function toggleWishlist(listingId, btn) {
  try {
    const res = await fetch(`/wishlist/${listingId}`, { method: 'POST', headers: { 'Content-Type': 'application/json' } });
    const data = await res.json();
    if (data.status === 'removed') {
      btn.closest('.col').style.transition = 'all 0.3s ease';
      btn.closest('.col').style.opacity = '0';
      btn.closest('.col').style.transform = 'scale(0.9)';
      setTimeout(() => btn.closest('.col').remove(), 300);
    }
  } catch(err) {
    console.error(err);
  }
}
</script>
