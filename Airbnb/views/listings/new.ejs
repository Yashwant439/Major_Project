<% layout("./layouts/boilerplate.ejs") -%>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.3/dist/leaflet.css" />

<div class="container mt-4">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="form-card">
        <h2 class="fw-bold text-center mb-4">Create New Listing</h2>
        <form method="POST" action="/listings" class="needs-validation" novalidate enctype="multipart/form-data">
          <div class="mb-3">
            <label for="title" class="form-label">Title</label>
            <input id="title" name="listing[title]" placeholder="Give your place a catchy name" class="form-control" required>
            <div class="invalid-feedback">Title is required</div>
          </div>
          <div class="mb-3">
            <label for="description" class="form-label">Description</label>
            <textarea id="description" name="listing[description]" rows="4" class="form-control" placeholder="Describe what makes your place special..." required></textarea>
            <div class="invalid-feedback">Description is required</div>
          </div>
          <div class="mb-3">
            <label for="image" class="form-label">Upload Image</label>
            <input id="image" name="listing[image]" type="file" class="form-control" accept="image/*" required onchange="previewImage(event)">
            <img id="imagePreview" src="" alt="" class="mt-2 rounded" style="max-width: 100%; max-height: 200px; display: none; object-fit: cover;">
          </div>
          <div class="row g-3">
            <div class="col-md-4">
              <label for="price" class="form-label">Price (₹/night)</label>
              <input id="price" name="listing[price]" type="number" min="1000" placeholder="e.g. 2500" class="form-control" required>
              <div class="invalid-feedback">Price is required (min ₹1000)</div>
            </div>
            <div class="col-md-4">
              <label for="category" class="form-label">Category</label>
              <select class="form-control" id="category" name="listing[category]" required>
                <option value="">Select Category</option>
                <option>Trending</option>
                <option>Room</option>
                <option>Amazing Views</option>
                <option>Surfing</option>
                <option>Amazing Pools</option>
                <option>Beach</option>
                <option>Cabins</option>
                <option>Mountain</option>
                <option>Iconic Cities</option>
              </select>
              <div class="invalid-feedback">Category is required</div>
            </div>
            <div class="col-md-4">
              <label for="country" class="form-label">Country</label>
              <input id="country" name="listing[country]" placeholder="e.g. India" class="form-control" required>
              <div class="invalid-feedback">Country is required</div>
            </div>
          </div>
          <div class="mb-3 mt-3">
            <label for="location" class="form-label">Location</label>
            <input id="location" name="listing[location]" placeholder="e.g. Kolkata, West Bengal" class="form-control" required>
            <div class="invalid-feedback">Location is required</div>
            <div id="map-preview" style="height: 220px; width: 100%; margin-top: 12px;"></div>
          </div>
          <input type="hidden" id="lat" name="listing[lat]">
          <input type="hidden" id="lng" name="listing[lng]">
          <button class="btn btn-primary w-100 mt-3" type="submit">
            <i class="fa-solid fa-plus me-1"></i> Create Listing
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.3/dist/leaflet.js"></script>
<script>
  function previewImage(e) {
    const preview = document.getElementById('imagePreview');
    const file = e.target.files[0];
    if (file) {
      preview.src = URL.createObjectURL(file);
      preview.style.display = 'block';
    }
  }

  let map, marker;
  function initMap(lat = 20.5937, lng = 78.9629) {
    if (map) map.remove();
    map = L.map('map-preview').setView([lat, lng], 4);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; OpenStreetMap contributors'
    }).addTo(map);
    marker = L.marker([lat, lng]).addTo(map);
  }
  async function updateMapFromLocation(locationText) {
    try {
      const url = `https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(locationText)}`;
      const res = await fetch(url, { headers: { 'User-Agent': 'wanderlust-app' } });
      const data = await res.json();
      if (data.length > 0) {
        const lat = parseFloat(data[0].lat);
        const lon = parseFloat(data[0].lon);
        map.setView([lat, lon], 13);
        marker.setLatLng([lat, lon]);
        document.getElementById('lat').value = lat;
        document.getElementById('lng').value = lon;
      }
    } catch(err) { console.error('Geocoding error:', err); }
  }
  document.addEventListener("DOMContentLoaded", () => {
    initMap();
    const locationInput = document.getElementById("location");
    let timeout;
    locationInput.addEventListener("input", (e) => {
      clearTimeout(timeout);
      timeout = setTimeout(() => {
        if (e.target.value.length > 3) updateMapFromLocation(e.target.value);
      }, 500);
    });
  });
</script>