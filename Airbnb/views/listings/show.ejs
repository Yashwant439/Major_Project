<% layout("./layouts/boilerplate.ejs") -%>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.3/dist/leaflet.css" />

<div class="container mt-4">
  <div class="row g-4">
    <!-- Main Content -->
    <div class="col-lg-8">
      <!-- Hero Image -->
      <img src="<%= listing.image.url %>" class="show-hero-img mb-4" alt="<%= listing.title %>" loading="lazy">

      <!-- Info Card -->
      <div class="show-info-card mb-4">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
          <div>
            <h2 class="fw-bold mb-1"><%= listing.title %></h2>
            <p class="mb-2" style="color: var(--text-secondary);">
              <i class="fa-solid fa-location-dot me-1"></i><%= listing.location %>, <%= listing.country %>
            </p>
          </div>
          <div class="d-flex align-items-center gap-2">
            <% if (listing.reviews.length > 0) { %>
              <div class="show-rating">
                <i class="fa-solid fa-star"></i> <%= avgRating %>
                <span style="font-weight: 400; font-size: 0.82rem; margin-left: 2px;">(<%= listing.reviews.length %> reviews)</span>
              </div>
            <% } %>
          </div>
        </div>
        <hr>
        <div class="mb-3">
          <h5 class="fw-bold mb-2">About this place</h5>
          <p style="color: var(--text-secondary); line-height: 1.7;"><%= listing.description %></p>
        </div>
        <div class="row g-3 mb-3">
          <div class="col-auto">
            <span class="badge bg-light text-dark border px-3 py-2" style="border-radius: 2rem;">
              <i class="fa-solid fa-tag me-1"></i><%= listing.category %>
            </span>
          </div>
          <div class="col-auto">
            <span class="badge bg-light text-dark border px-3 py-2" style="border-radius: 2rem;">
              <i class="fa-solid fa-indian-rupee-sign me-1"></i><%= listing.price.toLocaleString("en-IN") %> / night
            </span>
          </div>
        </div>
        <p style="font-size: 0.9rem; color: var(--text-secondary);">
          <i class="fa-solid fa-user me-1"></i> Hosted by <strong><%= listing.owner && listing.owner.username ? listing.owner.username : 'Yashwant' %></strong>
        </p>
        <% if (!currentUser || !listing.owner || !listing.owner._id.equals(currentUser._id)) { %>
          <a href="/listings/<%= listing._id %>/book" class="btn btn-primary mt-2">
            <i class="fa-solid fa-calendar-check me-1"></i> Reserve Now
          </a>
        <% } %>
        <% if(currentUser && listing.owner && listing.owner._id.equals(currentUser._id)) { %>
          <div class="d-flex gap-2 mt-2">
            <a href="/listings/<%= listing._id %>/edit" class="btn btn-outline-primary">
              <i class="fa-solid fa-pen me-1"></i> Edit
            </a>
            <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST">
              <button class="btn btn-outline-danger" type="submit">
                <i class="fa-solid fa-trash me-1"></i> Delete
              </button>
            </form>
          </div>
        <% } %>
      </div>

      <!-- Map -->
      <div class="show-info-card mb-4">
        <h5 class="fw-bold mb-3"><i class="fa-solid fa-map-location-dot me-2"></i>Location</h5>
        <div id="map" style="height: 320px; width: 100%;"></div>
        <p class="mt-2" style="font-size: 0.82rem; color: var(--text-muted);">
          <i class="fa-solid fa-info-circle me-1"></i>Exact location provided after booking
        </p>
      </div>

      <!-- Review Form -->
      <% if(currentUser) { %>
        <div class="show-info-card mb-4">
          <h5 class="fw-bold mb-3"><i class="fa-solid fa-pen-to-square me-2"></i>Leave a Review</h5>
          <form action="/listings/<%= listing._id %>/reviews" method="post" class="needs-validation" novalidate>
            <div class="mb-3">
              <label for="rating" class="form-label">Rating</label>
              <fieldset class="starability-slot">
                <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                <label for="first-rate1" title="Terrible">1 star</label>
                <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                <label for="first-rate2" title="Not good">2 stars</label>
                <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                <label for="first-rate3" title="Average">3 stars</label>
                <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                <label for="first-rate4" title="Very good">4 stars</label>
                <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                <label for="first-rate5" title="Amazing">5 stars</label>
              </fieldset>
            </div>
            <div class="mb-3">
              <label for="comment" class="form-label">Your Review</label>
              <textarea name="review[comment]" id="comment" rows="3" class="form-control" placeholder="Share your experience..." required></textarea>
              <div class="invalid-feedback">Please write a review</div>
            </div>
            <button class="btn btn-primary" type="submit">
              <i class="fa-solid fa-paper-plane me-1"></i> Submit Review
            </button>
          </form>
        </div>
      <% } %>

      <!-- All Reviews -->
      <% if(listing.reviews.length) { %>
        <div class="mb-4">
          <h5 class="fw-bold mb-3">
            <i class="fa-solid fa-message me-2"></i>Reviews
            <span class="show-rating ms-2" style="font-size: 0.82rem;">
              <i class="fa-solid fa-star"></i> <%= avgRating %> · <%= listing.reviews.length %> reviews
            </span>
          </h5>
          <div class="row g-3">
            <% listing.reviews.forEach(review => { %>
              <div class="col-md-6">
                <div class="review-card h-100">
                  <div class="d-flex justify-content-between align-items-center mb-2">
                    <div>
                      <span class="review-author">@<%= review.author ? review.author.username : 'Deleted User' %></span>
                      <span class="review-date ms-2">
                        <%= review.createdAt.toISOString().slice(0, 10) %>
                        <% if (review.updatedAt && review.updatedAt > review.createdAt) { %>
                          <span>(edited)</span>
                        <% } %>
                      </span>
                    </div>
                  </div>
                  <div class="review-stars mb-2">
                    <% for(let i = 1; i <= 5; i++) { %>
                      <i class="fa-<%= i <= review.rating ? 'solid' : 'regular' %> fa-star"></i>
                    <% } %>
                  </div>
                  <p style="color: var(--text-secondary); font-size: 0.9rem; margin: 0;"><%= review.comment %></p>
                  <% if(currentUser && review.author && review.author._id.equals(currentUser._id)) { %>
                    <div class="d-flex gap-2 mt-3">
                      <a href="/listings/<%= listing._id %>/reviews/<%= review._id %>/edit" class="btn btn-outline-primary btn-sm">Edit</a>
                      <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
                        <button class="btn btn-outline-danger btn-sm" type="submit">Delete</button>
                      </form>
                    </div>
                  <% } %>
                </div>
              </div>
            <% }); %>
          </div>
        </div>
      <% } %>
    </div>

    <!-- Sidebar (Booking CTA) -->
    <div class="col-lg-4">
      <div class="show-info-card" style="position: sticky; top: 90px;">
        <div class="text-center mb-3">
          <span style="font-size: 1.5rem; font-weight: 800;">&#8377;<%= listing.price.toLocaleString("en-IN") %></span>
          <span style="color: var(--text-secondary);">/ night</span>
        </div>
        <hr>
        <div class="d-flex justify-content-between mb-2" style="font-size: 0.9rem;">
          <span>Category</span>
          <span class="fw-bold"><%= listing.category %></span>
        </div>
        <div class="d-flex justify-content-between mb-2" style="font-size: 0.9rem;">
          <span>Location</span>
          <span class="fw-bold"><%= listing.location %></span>
        </div>
        <% if(listing.reviews.length > 0) { %>
          <div class="d-flex justify-content-between mb-2" style="font-size: 0.9rem;">
            <span>Rating</span>
            <span class="fw-bold"><i class="fa-solid fa-star" style="color: #ffc107;"></i> <%= avgRating %></span>
          </div>
        <% } %>
        <hr>
        <% if (!currentUser || !listing.owner || !listing.owner._id.equals(currentUser._id)) { %>
          <a href="/listings/<%= listing._id %>/book" class="btn btn-primary w-100">
            <i class="fa-solid fa-calendar-check me-1"></i> Reserve
          </a>
        <% } else { %>
          <p class="text-center" style="color: var(--text-secondary); font-size: 0.85rem;">This is your listing</p>
        <% } %>
      </div>
    </div>
  </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.3/dist/leaflet.js"></script>
<script>
  const coords = [<%= listing.geometry.coordinates[0] %>, <%= listing.geometry.coordinates[1] %>];
  const map = L.map('map').setView([coords[1], coords[0]], 13);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; OpenStreetMap contributors'
  }).addTo(map);
  L.marker([coords[1], coords[0]]).addTo(map)
    .bindPopup("<strong><%= listing.title %></strong><br><%= listing.location %>")
    .openPopup();
</script>
