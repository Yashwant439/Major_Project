<div class="toast-container" id="toastContainer">
  <% if(locals.success && locals.success.length) { %>
    <div class="toast-msg toast-success" onclick="this.classList.add('toast-exit'); setTimeout(() => this.remove(), 300)">
      <span class="toast-icon"><i class="fa-solid fa-circle-check"></i></span>
      <span><%= locals.success %></span>
      <button class="toast-close" onclick="event.stopPropagation(); this.parentElement.classList.add('toast-exit'); setTimeout(() => this.parentElement.remove(), 300)">&times;</button>
    </div>
  <% } %>
  <% if (locals.error && locals.error.length) { %>
    <div class="toast-msg toast-error" onclick="this.classList.add('toast-exit'); setTimeout(() => this.remove(), 300)">
      <span class="toast-icon"><i class="fa-solid fa-circle-exclamation"></i></span>
      <span><%= locals.error %></span>
      <button class="toast-close" onclick="event.stopPropagation(); this.parentElement.classList.add('toast-exit'); setTimeout(() => this.parentElement.remove(), 300)">&times;</button>
    </div>
  <% } %>
</div>
<script>
  // Auto-dismiss toasts
  setTimeout(() => {
    document.querySelectorAll('.toast-msg').forEach(t => {
      t.classList.add('toast-exit');
      setTimeout(() => t.remove(), 300);
    });
  }, 5000);
</script>