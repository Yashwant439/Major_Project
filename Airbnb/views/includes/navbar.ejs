<nav class="navbar navbar-expand-md sticky-top">
  <div class="container-fluid">
    <a class="navbar-brand" href="/listings">
      <i class="fa-solid fa-compass"></i>
      <span class="brand-text">WanderLust</span>
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNav">
      <div class="navbar-nav me-auto">
        <a class="nav-link" href="/listings">Explore</a>
        <a class="nav-link" href="/listings/new">Host</a>
      </div>
      <div class="search-box mx-auto">
        <form class="d-flex" role="search" method="GET" action="/listings/search">
          <input class="form-control" name="q" type="search" placeholder="Search destinations..." aria-label="Search" />
          <button class="btn" type="submit"><i class="fa-solid fa-search"></i></button>
        </form>
      </div>
      <div class="d-flex align-items-center gap-2 ms-auto">
        <button id="darkModeToggle" class="dark-mode-toggle" title="Toggle Dark Mode">
          <i class="fas fa-moon"></i>
        </button>
        <% if (!locals.currentUser) { %>
          <a class="nav-btn nav-btn-outline" href="/login">Log in</a>
          <a class="nav-btn nav-btn-primary" href="/register">Sign up</a>
        <% } else { %>
          <a href="/wishlist" class="nav-btn-icon" title="Wishlist">
            <i class="fa-regular fa-heart"></i>
          </a>
          <div class="user-menu" id="userMenu">
            <button class="user-menu-btn" onclick="document.getElementById('userMenu').classList.toggle('open')">
              <i class="fa-solid fa-bars" style="font-size: 0.8rem;"></i>
              <div class="user-avatar">
                <%= currentUser.username.charAt(0).toUpperCase() %>
              </div>
            </button>
            <div class="user-dropdown">
              <a href="/dashboard"><i class="fa-solid fa-gauge me-2"></i>Dashboard</a>
              <a href="/wishlist"><i class="fa-regular fa-heart me-2"></i>Wishlist</a>
              <a href="/listings/new"><i class="fa-solid fa-plus me-2"></i>Host your place</a>
              <hr>
              <a href="/logout"><i class="fa-solid fa-right-from-bracket me-2"></i>Log out</a>
            </div>
          </div>
        <% } %>
      </div>
    </div>
  </div>
